manifest {
    name            = 'nf-honeypi'
    author          = 'UKCEH Molecular Ecology'
    description     = 'Nextflow ITS2 amplicon pipeline for pollen/plant identification (honeypi v2)'
    nextflowVersion = '>=23.04.0'
    version         = '2.0.0'
}

params {
    // Input / output
    // Provide either a CSV samplesheet (--input) OR a directory of FASTQs (--input_dir)
    input     = null
    input_dir = null
    outdir    = 'results'

    // ITS region to extract ("ITS1" or "ITS2")
    its_region = 'ITS2'

    // RDP database
    // Supply either a local path to an already-extracted training directory
    // OR leave null to download via the URLs below.
    rdp_db_dir      = null
    rdp_db_cache    = "${projectDir}/db_cache"
    rdp_db_its2_url = 'https://sourceforge.net/projects/honeypi/files/Gweon-ITS2-20200325-rdp-trained.tar.gz'
    rdp_db_its1_url = 'https://sourceforge.net/projects/honeypi/files/Gweon-ITS1-20200325-rdp-trained.tar.gz'

    // DADA2 filtering parameters
    dada2_trunc_len_r1 = 230
    dada2_trunc_len_r2 = 190
    dada2_max_ee       = '2,2'

    // ITSx length filter (bp) after extraction
    its_min_len = 100
    its_max_len = 700

    // RDP confidence threshold for taxonomy assignment
    rdp_confidence = 0.5

    // R package library cache (shared across runs)
    r_lib_cache = "${HOME}/.nextflow_r_libs"

    // Resource caps
    max_memory = 64.GB
    max_cpus   = 16
    max_time   = 24.h
}

process {
    errorStrategy = { task.exitStatus in [104, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: process_low {
        cpus   = { 2  * task.attempt }
        memory = { 4.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 16.h * task.attempt }
    }
}

profiles {
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "/prj/DECODE/claude/edna-nextflow/work/singularity"
        docker.enabled         = false
        env.SINGULARITY_CACHEDIR = "/prj/DECODE/claude/edna-nextflow/work/singularity"
    }
    docker {
        docker.enabled         = true
        singularity.enabled    = false
    }
    test {
        params.input           = "${projectDir}/assets/test_samplesheet.csv"
        params.outdir          = 'test_results'
        params.dada2_trunc_len_r1 = 200
        params.dada2_trunc_len_r2 = 160
    }
}
